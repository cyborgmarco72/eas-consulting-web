{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Page",
  "type": "object",
  "required": [
    "id",
    "url",
    "slug",
    "title",
    "sections"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "meta": {
      "type": "object"
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}