{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Section",
  "type": "object",
  "required": [
    "id",
    "source_url"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "source_url": {
      "type": "string"
    },
    "headings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "paragraphs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "images": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}